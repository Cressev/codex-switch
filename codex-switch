#!/bin/bash
# Codex CLI 多账号管理工具
# 支持添加、删除、切换任意数量的 ChatGPT Plus 账号

set -e

# 配置文件路径
CODEX_DIR="$HOME/.codex"
AUTH_FILE="$CODEX_DIR/auth.json"
ACCOUNTS_DIR="$CODEX_DIR/accounts"
INDEX_FILE="$ACCOUNTS_DIR/index.json"

# 创建账号存储目录
mkdir -p "$ACCOUNTS_DIR"

# 初始化索引文件
if [ ! -f "$INDEX_FILE" ]; then
    echo '{"accounts": []}' > "$INDEX_FILE"
fi

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# 打印使用说明
show_usage() {
    echo -e "${BLUE}Codex CLI 多账号管理工具${NC}"
    echo ""
    echo "用法: codex-switch <命令> [参数]"
    echo ""
    echo "命令:"
    echo "  list, ls          列出所有已保存的账号"
    echo "  switch, sw <name> 切换到指定账号"
    echo "  add <name>        添加新账号 (自动引导登录)"
    echo "  remove, rm <name> 删除账号"
    echo "  rename <old> <new> 重命名账号"
    echo "  update [name]     重新登录并更新账号认证 (不指定则更新当前)"
    echo "  status            查看当前使用的账号"
    echo "  balance, bal [name] 查询账号余额 (不指定则查询全部)"
    echo "  help              显示此帮助信息"
    echo ""
    echo "示例:"
    echo "  codex-switch list                  # 列出所有账号"
    echo "  codex-switch switch work           # 切换到 work 账号"
    echo "  codex-switch sw personal           # 简写形式"
    echo "  codex-switch add backup            # 添加新账号 (自动登录)"
    echo "  codex-switch remove old-account    # 删除账号"
    echo "  codex-switch rename work main      # 重命名账号"
    echo "  codex-switch update                # 更新当前账号认证"
    echo "  codex-switch update work           # 更新指定账号认证"
    echo "  codex-switch status                # 查看当前账号"
    echo "  codex-switch balance               # 查询所有账号余额"
    echo "  codex-switch bal work              # 查询指定账号余额"
}

# 列出所有账号
list_accounts() {
    echo -e "${BLUE}已保存的账号:${NC}"
    echo ""

    local accounts=$(jq -r '.accounts[] | "\(.name)|\(.account_id)|\(.last_added)"' "$INDEX_FILE" 2>/dev/null || echo "")

    if [ -z "$accounts" ]; then
        echo -e "${YELLOW}还没有保存任何账号${NC}"
        echo ""
        echo "运行以下命令添加账号："
        echo "  codex-switch add <账号名称>"
        return
    fi

    # 获取当前账号 ID
    local current_id=$(jq -r '.tokens.account_id // ""' "$AUTH_FILE" 2>/dev/null || echo "")

    # 打印账号列表
    local counter=1
    while IFS='|' read -r name account_id last_added; do
        if [ "$account_id" = "$current_id" ]; then
            echo -e "${GREEN}✓ [${counter}] ${name}${NC} (当前)"
        else
            echo "  [${counter}] ${name}"
        fi
        echo "      账号 ID: ${account_id}"
        echo "      添加时间: ${last_added}"
        echo ""
        ((counter++))
    done <<< "$accounts"
}

# 检查当前账号
check_status() {
    if [ ! -f "$AUTH_FILE" ]; then
        echo -e "${RED}错误: 未找到认证文件 $AUTH_FILE${NC}"
        echo "请先运行 'codex login' 登录 Codex"
        exit 1
    fi

    echo -e "${BLUE}当前账号信息:${NC}"
    ACCOUNT_ID=$(jq -r '.tokens.account_id // "未知"' "$AUTH_FILE" 2>/dev/null || echo "未知")
    AUTH_MODE=$(jq -r '.auth_mode // "未知"' "$AUTH_FILE" 2>/dev/null || echo "未知")
    LAST_REFRESH=$(jq -r '.last_refresh // "未知"' "$AUTH_FILE" 2>/dev/null || echo "未知")

    echo "账号 ID: $ACCOUNT_ID"
    echo "认证模式: $AUTH_MODE"
    echo "最后刷新: $LAST_REFRESH"

    # 查找对应的账号名称
    local name=$(jq -r --arg id "$ACCOUNT_ID" '.accounts[] | select(.account_id == $id) | .name' "$INDEX_FILE" 2>/dev/null || echo "")
    
    if [ -n "$name" ]; then
        echo -e "${GREEN}当前使用: ${name}${NC}"
    else
        echo -e "${YELLOW}注意: 当前配置不在已保存的账号列表中${NC}"
    fi
}

# 添加新账号
add_account() {
    local name=$1

    if [ -z "$name" ]; then
        echo -e "${RED}错误: 请提供账号名称${NC}"
        echo "用法: codex-switch add <账号名称>"
        exit 1
    fi

    # 检查名称是否已存在
    if jq -e --arg name "$name" '.accounts[] | select(.name == $name)' "$INDEX_FILE" &>/dev/null; then
        echo -e "${YELLOW}账号名称 '$name' 已存在${NC}"
        echo "请选择操作:"
        echo "  1) 更新该账号的认证 (update)"
        echo "  2) 换一个名称"
        echo "  3) 取消"
        echo -n "请输入 (1/2/3): "
        read -r choice
        case "$choice" in
            1)
                update_account "$name"
                return
                ;;
            2)
                echo -n "请输入新名称: "
                read -r new_name
                if [ -z "$new_name" ]; then
                    echo "已取消"
                    exit 0
                fi
                if jq -e --arg name "$new_name" '.accounts[] | select(.name == $name)' "$INDEX_FILE" &>/dev/null; then
                    echo -e "${RED}名称 '$new_name' 也已存在，已取消${NC}"
                    exit 1
                fi
                name="$new_name"
                ;;
            *)
                echo "已取消"
                exit 0
                ;;
        esac
    fi

    # 备份当前 auth.json
    local temp_backup="$ACCOUNTS_DIR/.temp_add_backup.json"
    if [ -f "$AUTH_FILE" ]; then
        cp "$AUTH_FILE" "$temp_backup"
    fi

    # 运行 codex login
    echo -e "${CYAN}正在启动登录流程，请在浏览器中完成登录...${NC}"
    echo ""
    if ! codex login; then
        # 登录失败，恢复备份
        if [ -f "$temp_backup" ]; then
            cp "$temp_backup" "$AUTH_FILE"
        fi
        rm -f "$temp_backup"
        echo -e "${RED}✗ 登录失败${NC}"
        exit 1
    fi

    # 获取登录后的账号信息
    local account_id=$(jq -r '.tokens.account_id // ""' "$AUTH_FILE" 2>/dev/null || echo "")
    if [ -z "$account_id" ]; then
        # 恢复备份
        if [ -f "$temp_backup" ]; then
            cp "$temp_backup" "$AUTH_FILE"
        fi
        rm -f "$temp_backup"
        echo -e "${RED}✗ 无法获取登录账号信息${NC}"
        exit 1
    fi

    # 检查账号 ID 是否已被其他名称保存
    local existing_name=$(jq -r --arg id "$account_id" '.accounts[] | select(.account_id == $id) | .name' "$INDEX_FILE" 2>/dev/null || echo "")
    if [ -n "$existing_name" ] && [ "$existing_name" != "$name" ]; then
        echo -e "${YELLOW}警告: 该账号已以名称 '$existing_name' 保存${NC}"
        echo -n "是否继续以新名称 '$name' 保存? (y/n): "
        read -r reply
        if [[ ! $reply =~ ^[Yy]$ ]]; then
            # 恢复备份
            if [ -f "$temp_backup" ]; then
                cp "$temp_backup" "$AUTH_FILE"
            fi
            rm -f "$temp_backup"
            echo "已取消"
            exit 0
        fi
    fi

    # 保存账号文件
    local account_file="$ACCOUNTS_DIR/${name}.json"
    cp "$AUTH_FILE" "$account_file"

    # 添加到索引
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    jq --arg name "$name" \
       --arg id "$account_id" \
       --arg time "$timestamp" \
       '.accounts += [{"name": $name, "account_id": $id, "last_added": $time}]' \
       "$INDEX_FILE" > "${INDEX_FILE}.tmp" && mv "${INDEX_FILE}.tmp" "$INDEX_FILE"

    # 恢复之前的登录状态
    if [ -f "$temp_backup" ]; then
        cp "$temp_backup" "$AUTH_FILE"
        rm -f "$temp_backup"
    fi

    echo -e "${GREEN}✓ 已添加账号: ${name}${NC}"
    echo "账号 ID: $account_id"
    echo ""
    echo "现在可以运行以下命令切换账号："
    echo "  codex-switch switch $name"
}

# 切换账号
switch_account() {
    local name=$1

    if [ -z "$name" ]; then
        echo -e "${RED}错误: 请提供账号名称${NC}"
        echo "用法: codex-switch switch <账号名称>"
        echo ""
        echo "可用账号列表："
        list_accounts
        exit 1
    fi

    local account_file="$ACCOUNTS_DIR/${name}.json"

    if [ ! -f "$account_file" ]; then
        echo -e "${RED}错误: 账号 '$name' 不存在${NC}"
        echo ""
        echo "可用账号列表："
        list_accounts
        exit 1
    fi

    # 备份当前配置
    local backup_file="$ACCOUNTS_DIR/backup_$(date +%Y%m%d_%H%M%S).json"
    if [ -f "$AUTH_FILE" ]; then
        cp "$AUTH_FILE" "$backup_file"
        echo -e "${YELLOW}已备份当前配置到: $backup_file${NC}"
    fi

    # 切换到指定账号
    cp "$account_file" "$AUTH_FILE"

    # 获取账号信息
    local account_id=$(jq -r '.tokens.account_id' "$AUTH_FILE" 2>/dev/null || echo "")

    echo -e "${GREEN}✓ 已切换到账号: ${name}${NC}"
    echo "账号 ID: $account_id"
    echo ""
    echo -e "${BLUE}现在可以开始使用 Codex CLI 了！${NC}"
}

# 删除账号
remove_account() {
    local name=$1

    if [ -z "$name" ]; then
        echo -e "${RED}错误: 请提供账号名称${NC}"
        echo "用法: codex-switch remove <账号名称>"
        echo ""
        echo "可用账号列表："
        list_accounts
        exit 1
    fi

    # 检查账号是否存在
    if ! jq -e --arg name "$name" '.accounts[] | select(.name == $name)' "$INDEX_FILE" &>/dev/null; then
        echo -e "${RED}错误: 账号 '$name' 不存在${NC}"
        echo ""
        echo "可用账号列表："
        list_accounts
        exit 1
    fi

    # 确认删除
    echo -e "${YELLOW}警告: 即将删除账号 '$name'${NC}"
    echo "这个操作不可撤销！"
    echo -n "确认删除? (yes/no): "
    read -r confirmation

    if [ "$confirmation" != "yes" ]; then
        echo "已取消"
        exit 0
    fi

    # 删除账号文件
    local account_file="$ACCOUNTS_DIR/${name}.json"
    rm -f "$account_file"

    # 从索引中删除
    jq --arg name "$name" 'del(.accounts[] | select(.name == $name))' \
       "$INDEX_FILE" > "${INDEX_FILE}.tmp" && mv "${INDEX_FILE}.tmp" "$INDEX_FILE"

    echo -e "${GREEN}✓ 已删除账号: ${name}${NC}"
}

# 重命名账号
rename_account() {
    local old_name=$1
    local new_name=$2

    if [ -z "$old_name" ] || [ -z "$new_name" ]; then
        echo -e "${RED}错误: 请提供旧名称和新名称${NC}"
        echo "用法: codex-switch rename <旧名称> <新名称>"
        exit 1
    fi

    # 检查旧名称是否存在
    if ! jq -e --arg name "$old_name" '.accounts[] | select(.name == $name)' "$INDEX_FILE" &>/dev/null; then
        echo -e "${RED}错误: 账号 '$old_name' 不存在${NC}"
        echo ""
        echo "可用账号列表："
        list_accounts
        exit 1
    fi

    # 检查新名称是否已存在
    if jq -e --arg name "$new_name" '.accounts[] | select(.name == $name)' "$INDEX_FILE" &>/dev/null; then
        echo -e "${RED}错误: 账号名称 '$new_name' 已存在${NC}"
        exit 1
    fi

    # 重命名文件
    local old_file="$ACCOUNTS_DIR/${old_name}.json"
    local new_file="$ACCOUNTS_DIR/${new_name}.json"
    mv "$old_file" "$new_file"

    # 更新索引
    jq --arg old "$old_name" --arg new "$new_name" \
       '(.accounts[] | select(.name == $old)).name = $new' \
       "$INDEX_FILE" > "${INDEX_FILE}.tmp" && mv "${INDEX_FILE}.tmp" "$INDEX_FILE"

    echo -e "${GREEN}✓ 已重命名: ${old_name} → ${new_name}${NC}"
}

# 查询账号余额
check_balance() {
    local name=$1

    if [ -n "$name" ]; then
        local account_file="$ACCOUNTS_DIR/${name}.json"
        if [ ! -f "$account_file" ]; then
            echo -e "${RED}错误: 账号 '$name' 不存在${NC}"
            echo ""
            echo "可用账号列表："
            list_accounts
            exit 1
        fi
        echo -e "${BLUE}═══════════════════════════════════════${NC}"
        echo -e "${BLUE}查询余额: ${name}${NC}"
        echo -e "${BLUE}═══════════════════════════════════════${NC}"
        codex-balance-helper "${name}:${account_file}"
    else
        local accounts=$(jq -r '.accounts[] | "\(.name)|\(.account_id)"' "$INDEX_FILE" 2>/dev/null || echo "")

        if [ -z "$accounts" ]; then
            echo -e "${YELLOW}还没有保存任何账号${NC}"
            exit 0
        fi

        echo -e "${BLUE}═══════════════════════════════════════${NC}"
        echo -e "${BLUE}查询所有账号余额${NC}"
        echo -e "${BLUE}═══════════════════════════════════════${NC}"

        local helper_args=""
        while IFS='|' read -r acct_name acct_id; do
            local acct_file="$ACCOUNTS_DIR/${acct_name}.json"
            if [ -f "$acct_file" ]; then
                helper_args="$helper_args ${acct_name}:${acct_file}"
            else
                echo -e "\n${CYAN}▸ ${acct_name}${NC}"
                echo -e "  ${RED}✗ 认证文件不存在${NC}"
            fi
        done <<< "$accounts"

        if [ -n "$helper_args" ]; then
            codex-balance-helper $helper_args
        fi
    fi

    echo ""
    echo -e "${BLUE}═══════════════════════════════════════${NC}"
}

# 更新账号认证
update_account() {
    local name=$1

    # 如果没指定账号名，自动检测当前账号
    if [ -z "$name" ]; then
        if [ ! -f "$AUTH_FILE" ]; then
            echo -e "${RED}错误: 当前未登录，请指定要更新的账号名称${NC}"
            echo "用法: codex-switch update <账号名称>"
            exit 1
        fi
        local current_id=$(jq -r '.tokens.account_id // ""' "$AUTH_FILE" 2>/dev/null || echo "")
        name=$(jq -r --arg id "$current_id" '.accounts[] | select(.account_id == $id) | .name' "$INDEX_FILE" 2>/dev/null || echo "")
        if [ -z "$name" ]; then
            echo -e "${YELLOW}当前账号不在已保存列表中，请指定要更新的账号名称${NC}"
            echo "用法: codex-switch update <账号名称>"
            exit 1
        fi
        echo -e "${CYAN}检测到当前账号: ${name}${NC}"
    fi

    # 检查账号是否存在
    local account_file="$ACCOUNTS_DIR/${name}.json"
    if [ ! -f "$account_file" ]; then
        echo -e "${RED}错误: 账号 '$name' 不存在${NC}"
        echo ""
        echo "可用账号列表："
        list_accounts
        exit 1
    fi

    # 备份当前 auth.json
    local temp_backup="$ACCOUNTS_DIR/.temp_update_backup.json"
    if [ -f "$AUTH_FILE" ]; then
        cp "$AUTH_FILE" "$temp_backup"
    fi

    # 先切换到要更新的账号
    cp "$account_file" "$AUTH_FILE"

    # 运行 codex login 重新认证
    echo -e "${CYAN}正在为账号 '${name}' 重新登录，请在浏览器中完成登录...${NC}"
    echo ""
    if ! codex login; then
        # 登录失败，恢复备份
        if [ -f "$temp_backup" ]; then
            cp "$temp_backup" "$AUTH_FILE"
        fi
        rm -f "$temp_backup"
        echo -e "${RED}✗ 登录失败${NC}"
        exit 1
    fi

    # 获取更新后的账号信息
    local account_id=$(jq -r '.tokens.account_id // ""' "$AUTH_FILE" 2>/dev/null || echo "")
    if [ -z "$account_id" ]; then
        if [ -f "$temp_backup" ]; then
            cp "$temp_backup" "$AUTH_FILE"
        fi
        rm -f "$temp_backup"
        echo -e "${RED}✗ 无法获取登录账号信息${NC}"
        exit 1
    fi

    # 保存更新后的认证信息到账号文件
    cp "$AUTH_FILE" "$account_file"

    # 更新索引中的时间戳
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    jq --arg name "$name" --arg time "$timestamp" \
       '(.accounts[] | select(.name == $name)).last_added = $time' \
       "$INDEX_FILE" > "${INDEX_FILE}.tmp" && mv "${INDEX_FILE}.tmp" "$INDEX_FILE"

    # 恢复之前的登录状态
    if [ -f "$temp_backup" ]; then
        cp "$temp_backup" "$AUTH_FILE"
        rm -f "$temp_backup"
    fi

    echo -e "${GREEN}✓ 已更新账号: ${name}${NC}"
    echo "账号 ID: $account_id"
    echo "更新时间: $timestamp"
}

# 主逻辑
command=${1:-help}
arg1=${2:-""}
arg2=${3:-""}

case "$command" in
    list|ls)
        list_accounts
        ;;
    switch|sw)
        switch_account "$arg1"
        ;;
    add)
        add_account "$arg1"
        ;;
    remove|rm)
        remove_account "$arg1"
        ;;
    rename)
        rename_account "$arg1" "$arg2"
        ;;
    status)
        check_status
        ;;
    balance|bal)
        check_balance "$arg1"
        ;;
    update)
        update_account "$arg1"
        ;;
    help|--help|-h|"")
        show_usage
        ;;
    *)
        echo -e "${RED}错误: 未知命令 '$command'${NC}"
        echo ""
        show_usage
        exit 1
        ;;
esac
